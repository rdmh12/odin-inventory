<h1><%= category.name %></h1>
<%- include("message") %>
<div>
  <a href="/category/<%= category.id %>/edit" class="button">Edit</a>
  <form
    action="/category/<%= category.id %>/delete"
    method="post"
    class="inline"
  >
    <button type="submit" class="button">Delete</button>
    <input type="hidden" name="categoryName" value="<%= category.name %>" />
  </form>
</div>
<table>
  <tr>
    <th>ID</th>
    <th>Name</th>
    <th>Price</th>
    <th>In Stock</th>
  </tr>
  <% items.forEach((item) => { %>
  <tr>
    <td><%= item.id %></td>
    <td><a href="/item/<%= item.id %>"><%= item.name %></a></td>
    <td><%= item.price ?? "N/A" %></td>
    <td><%= item.in_stock ?? "N/A" %></td>
  </tr>
  <% }); %>
</table>
