<h1>category list</h1>
<%- include("message") %>
<div>
  <a href="/category/create" class="button">Create</a>
</div>
<table>
  <tr>
    <th>ID</th>
    <th>Name</th>
  </tr>
  <% categories.forEach((category) => { %>
  <tr>
    <td><%= category.id %></td>
    <td><a href="/category/<%= category.id %>"><%= category.name %></a></td>
    <td><%= category.item_count %></td>
  </tr>
  <% }); %>
</table>
